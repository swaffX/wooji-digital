# =====================================================================
# Caddy snippet: accept ONLY requests proxied by Cloudflare.
#
# Why: the app rate limiter (frontend/lib/rateLimit.ts) trusts the
# `CF-Connecting-IP` header to identify the real client. That header is
# only safe if NOBODY can reach the origin directly and forge it. This
# snippet 403s any request whose source IP is not a Cloudflare edge,
# so by the time a request reaches Next.js, CF-Connecting-IP is
# guaranteed to be set by Cloudflare and cannot be spoofed.
#
# Usage — in your site's Caddyfile:
#
#   woojidigital.com {
#       import cloudflare_only
#       encode zstd gzip
#       reverse_proxy 127.0.0.1:3000
#   }
#
# (Place the (cloudflare_only) snippet definition below near the top of
#  the Caddyfile, OR `import /path/to/cloudflare-allowlist.caddy`.)
#
# IP ranges below are Cloudflare's published edges. Refresh periodically
# from https://www.cloudflare.com/ips/ (they change rarely). For a
# zero-maintenance option use the caddy-cloudflare-ip / trusted_proxies
# module instead of this static list.
# =====================================================================

(cloudflare_only) {
	@not_cloudflare {
		not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}
	respond @not_cloudflare "Forbidden" 403 {
		close
	}
}
